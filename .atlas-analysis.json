  "keyFeatures": [
    "8 SSN resolution methods (Static, FreshyCalls, Hell's/Halo's/Tartarus' Gate, SyscallsFromDisk, RecycledGate, HW Breakpoint)",
    "4 invocation methods (Embedded, Indirect, Randomized, Egg Hunt)",
    "Multi-architecture support (x64, x86, WoW64, ARM64)",
